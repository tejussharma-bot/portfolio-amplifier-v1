# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Database
# Use the Supabase Session Pooler string on Render or other IPv4-only environments.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:5432/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_ai
DB_USER=postgres
DB_PASS=your_password
DB_SSL=true

# JWT
JWT_SECRET=super_secure_jwt_secret_change_this

# Google OAuth (Login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-render-service.onrender.com/api/auth/google/callback

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_AUTH_REDIRECT_URI=https://your-render-service.onrender.com/api/auth/linkedin/callback
LINKEDIN_REDIRECT_URI=https://your-render-service.onrender.com/api/channels/linkedin/callback

# Dribbble API (Publishing)
DRIBBBLE_CLIENT_ID=your_dribbble_client_id
DRIBBBLE_CLIENT_SECRET=your_dribbble_client_secret
DRIBBBLE_REDIRECT_URI=https://your-render-service.onrender.com/api/channels/dribbble/callback

# File Uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# AI Service (Mock or Real Endpoint)
AI_SERVICE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_key
