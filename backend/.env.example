# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_ai
DB_USER=postgres
DB_PASS=your_password

# JWT
JWT_SECRET=super_secure_jwt_secret_change_this

# Google OAuth (Login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# LinkedIn API (Publishing)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/channels/linkedin/callback

# Dribbble API (Publishing)
DRIBBBLE_CLIENT_ID=your_dribbble_client_id
DRIBBBLE_CLIENT_SECRET=your_dribbble_client_secret
DRIBBBLE_REDIRECT_URI=http://localhost:3000/api/channels/dribbble/callback

# AI Service (mock fallback remains available if these are empty)
AI_SERVICE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_key
AI_MODEL=gpt-4o-mini
