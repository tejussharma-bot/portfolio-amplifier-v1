# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
ALLOWED_HOSTS=localhost:3000,localhost:3001,portfolio-amplifier-v1.vercel.app

# Database
# On Vercel, prefer the Supabase Transaction Pooler string.
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-your-region.pooler.supabase.com:6543/postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_ai
DB_USER=postgres
DB_PASS=your_password
DB_SSL=true

# JWT
JWT_SECRET=super_secure_jwt_secret_change_this

# Google OAuth (Login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-vercel-app.vercel.app/api/auth/google/callback
GOOGLE_CHANNEL_REDIRECT_URI=https://your-vercel-app.vercel.app/api/channels/googlemybusiness/callback

# LinkedIn API
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_AUTH_REDIRECT_URI=https://your-vercel-app.vercel.app/api/auth/linkedin/callback
LINKEDIN_REDIRECT_URI=https://your-vercel-app.vercel.app/api/channels/linkedin/callback

# Dribbble API (Publishing)
DRIBBBLE_CLIENT_ID=your_dribbble_client_id
DRIBBBLE_CLIENT_SECRET=your_dribbble_client_secret
DRIBBBLE_REDIRECT_URI=https://your-vercel-app.vercel.app/api/channels/dribbble/callback

# File Uploads
# Preferred free option: Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=project-assets

# Optional fallback: Vercel Blob
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# AI Service (Optional)
# Leave AI_API_KEY unset to use the free deterministic fallback generators.
AI_SERVICE_URL=https://api.openai.com/v1
AI_API_KEY=your_openai_key
